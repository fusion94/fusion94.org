---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description || ''} image={heroImage} />
  </head>
  <body>
    <Header />
    <main>
      <article>
        <!-- Back link -->
        <a href="/blog" class="back-link">
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
          </svg>
          Back to blog
        </a>

        <!-- Tags -->
        {tags && tags.length > 0 && (
          <div class="post-tags">
            {tags.map((tag: string) => (
              <a href={`/blog?tag=${tag}`} class="tag">{tag}</a>
            ))}
          </div>
        )}

        <!-- Header -->
        <header class="post-header">
          <h1>{title}</h1>
          <div class="post-meta">
            <span>Tony Guntharp</span>
            <span class="dot">·</span>
            <time datetime={pubDate.toISOString()}>{formattedDate}</time>
            {updatedDate && (
              <>
                <span class="dot">·</span>
                <span>Updated {updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              </>
            )}
          </div>
        </header>

        <!-- Hero image -->
        {heroImage && (
          <div class="hero-image">
            <img src={heroImage} alt={title} />
          </div>
        )}

        <!-- Content -->
        <div class="prose">
          <slot />
        </div>

        <!-- Footer nav -->
        <footer class="post-footer">
          <a href="/blog" class="back-link-bottom">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
            </svg>
            All posts
          </a>
        </footer>
      </article>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: 768px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  article {
    padding: 3rem 0 5rem;
  }

  /* Back link */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--accent); }

  /* Tags */
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }
  .tag {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    font-size: 0.75rem;
    font-weight: 500;
    background: rgba(245,158,11,0.1);
    color: var(--accent);
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .tag:hover { background: rgba(245,158,11,0.2); color: var(--accent); }

  /* Post header */
  .post-header {
    margin-bottom: 2rem;
  }
  .post-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.15;
    margin: 0.5rem 0 1rem;
    color: var(--text-primary);
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
  }
  .dot { color: var(--text-muted); }

  /* Hero image */
  .hero-image {
    margin-bottom: 2.5rem;
  }
  .hero-image img {
    width: 100%;
    max-height: 420px;
    object-fit: cover;
    border-radius: 14px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }

  /* Prose */
  .prose {
    line-height: 1.8;
    font-size: 1.0625rem;
  }
  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    color: var(--text-primary);
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose :global(h1) { font-size: 1.875rem; }
  .prose :global(h2) { font-size: 1.5rem; }
  .prose :global(h3) { font-size: 1.25rem; font-weight: 600; }
  .prose :global(p) {
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
  }
  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }
  .prose :global(a:hover) { color: var(--accent-hover); }
  .prose :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
  }
  .prose :global(ul) { list-style-type: disc; }
  .prose :global(ol) { list-style-type: decimal; }
  .prose :global(li) { margin-bottom: 0.5rem; }
  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: rgba(245,158,11,0.05);
    border-radius: 0 8px 8px 0;
    font-style: italic;
  }
  .prose :global(blockquote p) { margin-bottom: 0; }
  .prose :global(pre) {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    overflow-x: auto;
    font-size: 0.875rem;
    margin: 1.5rem 0;
  }
  .prose :global(code) {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }
  .prose :global(:not(pre) > code) {
    background: rgba(245,158,11,0.1);
    color: var(--accent);
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-size: 0.875em;
  }
  .prose :global(img) {
    max-width: 100%;
    border-radius: 10px;
    margin: 1.5rem 0;
  }
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }
  .prose :global(th),
  .prose :global(td) {
    border: 1px solid var(--border);
    padding: 0.625rem 0.875rem;
    text-align: left;
  }
  .prose :global(th) {
    background: var(--bg-card);
    font-weight: 600;
    color: var(--text-primary);
  }
  .prose :global(td) { color: var(--text-secondary); }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  /* Post footer */
  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .back-link-bottom {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    transition: color 0.2s;
  }
  .back-link-bottom:hover { color: var(--accent-hover); }

  @media (max-width: 640px) {
    article { padding: 2rem 0 4rem; }
    .post-header h1 { font-size: 1.75rem; }
  }
</style>
