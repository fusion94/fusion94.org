---
interface Props {
  chart: string;
  title?: string;
  caption?: string;
}

const { chart, title, caption } = Astro.props;
---

<figure class="mermaid-figure">
  {title && <figcaption class="mermaid-title">{title}</figcaption>}
  <div class="mermaid-diagram" data-mermaid>{chart}</div>
  {caption && <p class="mermaid-caption">{caption}</p>}
</figure>

<script>
  import mermaid from 'mermaid';

  const initMermaid = async () => {
    if (!window.__atlasMermaidInitialized) {
      mermaid.initialize({
        startOnLoad: false,
        securityLevel: 'loose',
        theme: 'neutral'
      });
      window.__atlasMermaidInitialized = true;
    }

    const nodes = Array.from(document.querySelectorAll('[data-mermaid]')).filter(
      (node) => !node.dataset.rendered
    );

    if (!nodes.length) return;

    await mermaid.run({ nodes });
    nodes.forEach((node) => {
      node.dataset.rendered = 'true';
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      void initMermaid();
    }, { once: true });
  } else {
    void initMermaid();
  }
</script>

<style>
  .mermaid-figure {
    margin: 1.75rem 0;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.02);
  }

  .mermaid-title {
    display: block;
    margin-bottom: 0.75rem;
    font-weight: 700;
  }

  .mermaid-diagram {
    overflow-x: auto;
    background: transparent;
    padding: 0;
    margin: 0;
  }

  .mermaid-diagram :global(svg) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 0 auto;
  }

  .mermaid-caption {
    margin: 0.75rem 0 0;
    font-size: 0.95rem;
    opacity: 0.8;
  }
</style>
