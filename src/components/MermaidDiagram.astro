---
interface Props {
  chart: string;
  title?: string;
  caption?: string;
}

const { chart, title, caption } = Astro.props;
---

<figure class="mermaid-figure">
  {title && <figcaption class="mermaid-title">{title}</figcaption>}
  <div class="mermaid-diagram" data-mermaid>{chart}</div>
  {caption && <p class="mermaid-caption">{caption}</p>}
</figure>

<script>
  import mermaid from 'mermaid';

  if (!window.__mermaidInitialized) {
    mermaid.initialize({
      startOnLoad: false,
      securityLevel: 'loose',
      theme: 'neutral',
    });
    window.__mermaidInitialized = true;
  }

  async function renderDiagrams() {
    const nodes = document.querySelectorAll<HTMLElement>('[data-mermaid]:not([data-rendered])');
    for (const node of nodes) {
      const chart = node.textContent?.trim() ?? '';
      if (!chart) continue;
      const id = `mermaid-${Math.random().toString(36).slice(2)}`;
      try {
        const { svg } = await mermaid.render(id, chart);
        node.innerHTML = svg;
        node.dataset.rendered = 'true';
      } catch (err) {
        console.error('Mermaid render error:', err);
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', renderDiagrams, { once: true });
  } else {
    void renderDiagrams();
  }
</script>

<style>
  .mermaid-figure {
    margin: 1.75rem 0;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.02);
  }

  .mermaid-title {
    display: block;
    margin-bottom: 0.75rem;
    font-weight: 700;
  }

  .mermaid-diagram {
    overflow-x: auto;
    background: transparent;
    padding: 0;
    margin: 0;
  }

  .mermaid-diagram :global(svg) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 0 auto;
  }

  .mermaid-caption {
    margin: 0.75rem 0 0;
    font-size: 0.95rem;
    opacity: 0.8;
  }
</style>
