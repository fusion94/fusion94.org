---
interface Props {
  chart: string;
  title?: string;
  caption?: string;
}

const { chart, title, caption } = Astro.props;
---

<figure class="mermaid-figure">
  {title && <figcaption class="mermaid-title">{title}</figcaption>}
  <div class="mermaid-diagram" data-mermaid>{chart}</div>
  {caption && <p class="mermaid-caption">{caption}</p>}
</figure>

<script>
  import mermaid from 'mermaid';

  if (!window.__mermaidInitialized) {
    mermaid.initialize({
      startOnLoad: false,
      securityLevel: 'loose',
      theme: 'dark',
      themeVariables: {
        background:              '#0f1629',
        primaryColor:           '#1a2240',
        primaryTextColor:       '#f1f5f9',
        primaryBorderColor:     '#f59e0b',
        lineColor:              '#94a3b8',
        secondaryColor:         '#0f1629',
        tertiaryColor:          '#0a0e1a',
        mainBkg:                '#1a2240',
        nodeBorder:             '#f59e0b',
        clusterBkg:             '#0f1629',
        clusterBorder:          'rgba(245,158,11,0.3)',
        titleColor:             '#fbbf24',
        edgeLabelBackground:    '#1a2240',
        nodeTextColor:          '#f1f5f9',
        labelTextColor:         '#f1f5f9',
      },
      flowchart: {
        curve: 'basis',
        padding: 20,
      },
    });
    window.__mermaidInitialized = true;
  }

  async function renderDiagrams() {
    const nodes = document.querySelectorAll<HTMLElement>('[data-mermaid]:not([data-rendered])');
    for (const node of nodes) {
      const chart = node.textContent?.trim() ?? '';
      if (!chart) continue;
      const id = `mermaid-${Math.random().toString(36).slice(2)}`;
      try {
        const { svg } = await mermaid.render(id, chart);
        node.innerHTML = svg;
        node.dataset.rendered = 'true';
      } catch (err) {
        console.error('Mermaid render error:', err);
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', renderDiagrams, { once: true });
  } else {
    void renderDiagrams();
  }
</script>

<style>
  .mermaid-figure {
    margin: 2rem 0;
    border: 1px solid rgba(245, 158, 11, 0.25);
    border-radius: 14px;
    background: #0f1629;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.35);
  }

  .mermaid-title {
    display: block;
    padding: 0.8rem 1.25rem;
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.01em;
    color: #fbbf24;
    background: rgba(245, 158, 11, 0.07);
    border-bottom: 1px solid rgba(245, 158, 11, 0.15);
  }

  .mermaid-diagram {
    overflow-x: auto;
    padding: 1.5rem 1.25rem;
  }

  .mermaid-diagram :global(svg) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 0 auto;
  }

  .mermaid-caption {
    margin: 0;
    padding: 0.65rem 1.25rem;
    font-size: 0.825rem;
    font-style: italic;
    color: #64748b;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }
</style>
