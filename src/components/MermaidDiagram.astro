---
interface Props {
  chart: string;
  title?: string;
  caption?: string;
}

const { chart, title, caption } = Astro.props;
const diagramId = `mermaid-${Math.random().toString(36).slice(2, 10)}`;
---

<figure class="mermaid-figure">
  {title && <figcaption class="mermaid-title">{title}</figcaption>}
  <pre id={diagramId} class="mermaid">{chart}</pre>
  {caption && <p class="mermaid-caption">{caption}</p>}
</figure>

<script type="module" is:inline>
  import mermaid from 'mermaid';

  if (!window.__atlasMermaidInitialized) {
    mermaid.initialize({
      startOnLoad: false,
      securityLevel: 'loose',
      theme: 'neutral'
    });
    window.__atlasMermaidInitialized = true;
  }

  mermaid.run({ querySelector: '.mermaid' });
</script>

<style>
  .mermaid-figure {
    margin: 1.75rem 0;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.02);
  }

  .mermaid-title {
    display: block;
    margin-bottom: 0.75rem;
    font-weight: 700;
  }

  .mermaid {
    overflow-x: auto;
    background: transparent;
    padding: 0;
    margin: 0;
  }

  .mermaid :global(svg) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 0 auto;
  }

  .mermaid-caption {
    margin: 0.75rem 0 0;
    font-size: 0.95rem;
    opacity: 0.8;
  }
</style>
