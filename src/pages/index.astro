---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
).slice(0, 6);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>

      <!-- Hero -->
      <section class="hero-section">
        <div class="hero-glow"></div>
        <div class="hero-content">
          <h1 class="hero-title">Tony Guntharp</h1>
          <p class="hero-sub">{SITE_DESCRIPTION}</p>
          <div class="hero-actions">
            <a href="/blog" class="btn-primary">Read the Blog →</a>
            <a href="/about" class="btn-outline">About Me</a>
          </div>
        </div>
      </section>

      <!-- Latest Posts -->
      <section class="posts-section">
        <div class="section-header">
          <h2>Latest Posts</h2>
          <a href="/blog" class="view-all">View all →</a>
        </div>
        <div class="post-grid">
          {posts.map((post) => (
            <a href={`/blog/${post.id}/`} class="post-card">
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="card-tags">
                  {post.data.tags.slice(0, 3).map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
              <h3 class="card-title">{post.data.title}</h3>
              {post.data.description && (
                <p class="card-excerpt">{post.data.description}</p>
              )}
              <div class="card-meta">
                <span>Tony Guntharp</span>
                <span class="dot">·</span>
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric', month: 'long', day: 'numeric'
                  })}
                </time>
              </div>
            </a>
          ))}
        </div>
        <div class="view-all-wrap">
          <a href="/blog" class="view-all-btn">View all posts →</a>
        </div>
      </section>

    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Hero */
  .hero-section {
    position: relative;
    overflow: hidden;
    padding: 6rem 0 4rem;
  }
  .hero-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 20% 50%, rgba(245,158,11,0.08) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(249,115,22,0.05) 0%, transparent 50%);
    pointer-events: none;
  }
  .hero-content {
    position: relative;
  }
  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    margin: 0 0 1rem;
    color: var(--text-primary);
  }
  .hero-sub {
    font-size: 1.15rem;
    color: var(--text-secondary);
    max-width: 540px;
    margin: 0 0 2rem;
    line-height: 1.6;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .btn-primary {
    display: inline-block;
    padding: 0.7rem 1.5rem;
    background: var(--accent);
    color: #0a0e1a;
    font-weight: 700;
    font-size: 0.9rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: var(--accent-hover); color: #0a0e1a; }
  .btn-outline {
    display: inline-block;
    padding: 0.7rem 1.5rem;
    border: 1px solid var(--border);
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 0.9rem;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-outline:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Posts section */
  .posts-section {
    padding: 2rem 0 4rem;
  }
  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
  }
  .section-header h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
  }
  .view-all {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    transition: color 0.2s;
  }
  .view-all:hover { color: var(--accent-hover); }

  /* Post grid */
  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .post-card {
    display: block;
    padding: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    text-decoration: none;
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
  }
  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.4);
    border-color: rgba(245,158,11,0.25);
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }
  .tag {
    display: inline-block;
    padding: 0.125rem 0.5rem;
    font-size: 0.72rem;
    font-weight: 500;
    background: rgba(245,158,11,0.1);
    color: var(--accent);
    border-radius: 4px;
    text-decoration: none;
  }
  .card-title {
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 0.6rem;
    color: var(--text-primary);
    transition: color 0.2s;
    line-height: 1.35;
  }
  .post-card:hover .card-title { color: var(--accent-hover); }
  .card-excerpt {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0 0 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: var(--text-muted);
  }
  .dot { color: var(--text-muted); }

  .view-all-wrap {
    text-align: center;
    margin-top: 2.5rem;
  }
  .view-all-btn {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
  }
  .view-all-btn:hover { color: var(--accent-hover); }

  @media (max-width: 1024px) {
    .post-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .hero-title { font-size: 2.2rem; }
    .post-grid { grid-template-columns: 1fr; }
  }
</style>
